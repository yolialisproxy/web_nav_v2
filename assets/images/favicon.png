<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <!-- 主渐变 - 紫蓝色渐变 -->
    <linearGradient id="mainGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#764ba2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f093fb;stop-opacity:1" />
    </linearGradient>
    
    <!-- 背景渐变 -->
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
    
    <!-- 光泽效果 -->
    <linearGradient id="shineGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:white;stop-opacity:0.3" />
      <stop offset="50%" style="stop-color:white;stop-opacity:0" />
      <stop offset="100%" style="stop-color:black;stop-opacity:0.1" />
    </linearGradient>
    
    <!-- 阴影滤镜 -->
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#764ba2" flood-opacity="0.3"/>
    </filter>
  </defs>
  
  <!-- 主背景圆角矩形 -->
  <rect width="512" height="512" rx="100" fill="url(#bgGradient)" filter="url(#shadow)"/>
  
  <!-- 光泽层 -->
  <rect width="512" height="512" rx="100" fill="url(#shineGradient)"/>
  
  <!-- 装饰性圆环 -->
  <circle cx="256" cy="256" r="200" fill="none" stroke="white" stroke-width="2" opacity="0.1"/>
  <circle cx="256" cy="256" r="180" fill="none" stroke="white" stroke-width="1.5" opacity="0.08"/>
  
  <!-- KenHun 文字 -->
  <g font-family="'SF Pro Display', 'Helvetica Neue', Arial, sans-serif">
    <!-- K -->
    <text x="80" y="290" font-size="180" font-weight="800" fill="white" opacity="0.95">K</text>
    
    <!-- en -->
    <text x="195" y="290" font-size="140" font-weight="600" fill="white" opacity="0.9">en</text>
    
    <!-- H -->
    <text x="310" y="290" font-size="180" font-weight="800" fill="white" opacity="0.95">H</text>
    
    <!-- un -->
    <text x="410" y="290" font-size="140" font-weight="600" fill="white" opacity="0.9">un</text>
  </g>
  
  <!-- 底部装饰线 -->
  <line x1="120" y1="340" x2="392" y2="340" stroke="white" stroke-width="3" opacity="0.3" stroke-linecap="round"/>
  
  <!-- 角落装饰点 -->
  <circle cx="80" cy="80" r="15" fill="white" opacity="0.2"/>
  <circle cx="432" cy="80" r="15" fill="white" opacity="0.2"/>
  <circle cx="80" cy="432" r="15" fill="white" opacity="0.2"/>
  <circle cx="432" cy="432" r="15" fill="white" opacity="0.2"/>
</svg>