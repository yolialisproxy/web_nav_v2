{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./assets/js",
    "outDir": "./assets/js",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "assets/js/**/*.js",
    "assets/js/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
