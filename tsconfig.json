{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./assets/js",
    "outDir": "./assets/js",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "removeComments": false,
    "sourceMap": true,
    "types": []
  },
  "include": [
    "assets/js/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}