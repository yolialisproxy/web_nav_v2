{
  "compilerOptions": {
    "target": "es2017",
    "module": "none",
    "rootDir": "./assets/js",
    "outDir": "./assets/js",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "removeComments": false,
    "sourceMap": true,
    "lib": [
      "es2019",
      "dom"
    ],
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "assets/js/**/*.ts",
    "assets/js/**/*.d.ts",
    "assets/js/global.d.ts",
    "**/*.ts",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}