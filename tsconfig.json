{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "removeComments": false,
    "sourceMap": true,
    "lib": [
      "es2019",
      "dom",
      "webworker"
    ],
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "strict": false,
    "allowJs": false,
    "checkJs": false,
    "noEmitOnError": false,
    "outDir": ".",
    "rootDir": ".",
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "assets/js/**/*.ts",
    "assets/js/**/*.d.ts",
    "assets/js/global.d.ts",
    "global.d.ts",
    "*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}